# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/beautypass

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (AES-256, 32 bytes hex)
ENCRYPTION_KEY=change-me-32-byte-hex-key-here!!

# Storage
STORAGE_PATH=./uploads
S3_COMPATIBLE=false
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

# AI
ANTHROPIC_API_KEY=

# Email (optional for dev — set SKIP_EMAIL=true to log instead)
SKIP_EMAIL=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@beautypass.app

# App
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
QR_TOKEN_RETENTION_DAYS=90
