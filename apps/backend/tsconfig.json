{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@beautypass/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
